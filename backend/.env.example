# Backend Environment Variables Template
# Copy this file to .env and configure with your values

# Database Configuration
# For Docker: Use container name "db" as hostname (already configured)
# For local development: Use "localhost" and ensure PostgreSQL is running
POSTGRES_DB=orderdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here

# JWT Secret
# For development: Can use any string >= 256 bits
# For production: Generate a new one using:
#   openssl rand -base64 32
# Or using Python:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-jwt-secret-key-minimum-256-bits-long

# Security Notes:
# - Each environment (dev, staging, prod) should have different secrets
# - NEVER commit the actual .env file to version control
# - Use a secrets manager (AWS Secrets Manager, Vault, etc.) in production
# - Rotate secrets periodically
# - Use strong, randomly generated values

